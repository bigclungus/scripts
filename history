#!/usr/bin/env python3
"""
Discord history semantic search.

Usage:
  history <query>
  history <query> --limit 10
  history <query> --author centronias
"""

import sys
import os
import argparse
import sqlite3
import struct

import sqlite_vec
from openai import OpenAI

DB_PATH = "/mnt/data/data/discord-history.db"
EMBED_MODEL = "text-embedding-3-small"
EMBED_DIMS = 1536


def get_openai_key() -> str:
    key = os.environ.get("OPENAI_API_KEY")
    if key:
        return key

    env_files = [
        "/mnt/data/temporal-workflows/.env",
        "/mnt/data/.env",
        "/home/clungus/.claude/channels/discord/.env",
    ]
    for path in env_files:
        if os.path.exists(path):
            with open(path) as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("OPENAI_API_KEY="):
                        val = line.split("=", 1)[1].strip()
                        if val:
                            return val

    print("ERROR: OPENAI_API_KEY not found in environment or any known .env files.", file=sys.stderr)
    sys.exit(1)


def open_db() -> sqlite3.Connection:
    if not os.path.exists(DB_PATH):
        print(f"ERROR: Database not found at {DB_PATH}. Run history-ingest.py first.", file=sys.stderr)
        sys.exit(1)

    conn = sqlite3.connect(DB_PATH)
    conn.enable_load_extension(True)
    sqlite_vec.load(conn)
    conn.enable_load_extension(False)
    return conn


def embed_query(client: OpenAI, query: str) -> bytes:
    response = client.embeddings.create(
        model=EMBED_MODEL,
        input=[query],
    )
    return sqlite_vec.serialize_float32(response.data[0].embedding)


def format_ts(ts: str) -> str:
    """Format ISO timestamp to [YYYY-MM-DD HH:MM]."""
    try:
        # Handle both with and without fractional seconds
        ts_clean = ts.replace("Z", "+00:00")
        from datetime import datetime, timezone
        dt = datetime.fromisoformat(ts_clean).astimezone(timezone.utc)
        return dt.strftime("%Y-%m-%d %H:%M")
    except Exception:
        return ts[:16] if ts else "unknown"


def search(query: str, limit: int = 5, author_filter: str = None):
    api_key = get_openai_key()
    client = OpenAI(api_key=api_key)
    conn = open_db()

    query_emb = embed_query(client, query)

    # KNN search via sqlite-vec
    results = conn.execute(
        """
        SELECT
            m.id,
            m.message_id,
            m.author,
            m.channel_id,
            m.ts,
            m.content,
            v.distance
        FROM messages_vec v
        JOIN messages m ON m.id = v.rowid
        WHERE v.embedding MATCH ?
          AND k = ?
        ORDER BY v.distance
        """,
        (query_emb, limit * 3 if author_filter else limit)
    ).fetchall()

    conn.close()

    if not results:
        print("No results found.")
        return

    # Apply author filter if requested
    if author_filter:
        results = [r for r in results if author_filter.lower() in r[2].lower()]
        results = results[:limit]

    if not results:
        print(f"No results found for author '{author_filter}'.")
        return

    for row in results:
        _, message_id, author, channel_id, ts, content, distance = row
        ts_fmt = format_ts(ts)
        # Truncate very long messages
        if len(content) > 300:
            content = content[:297] + "..."
        print(f"[{ts_fmt}] {author}: {content}")


def main():
    parser = argparse.ArgumentParser(
        description="Search Discord message history semantically.",
        usage="history <query> [--limit N] [--author NAME]"
    )
    parser.add_argument("query", nargs="+", help="Search query")
    parser.add_argument("--limit", type=int, default=5, help="Number of results (default: 5)")
    parser.add_argument("--author", type=str, default=None, help="Filter by author name")

    args = parser.parse_args()
    query = " ".join(args.query)

    search(query, limit=args.limit, author_filter=args.author)


if __name__ == "__main__":
    main()
